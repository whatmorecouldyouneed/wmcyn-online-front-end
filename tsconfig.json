{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    "**/*-WMCYN-MACHINE.ts",
    "**/*-WMCYN-MACHINE.tsx",
    "**/*-WMCYN-MACHINE.scss",
    "src/ar/templates/**",
    "src/utils/markerSync.ts",
    "src/utils/testMarkerSync.ts"
  ]
}
